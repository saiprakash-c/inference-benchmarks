#!/usr/bin/env bash
# Manage the runtime container (GPU, Thor only).
#
# Usage:
#   ./bin/docker_rt          # enter the container
#   ./bin/docker_rt --build  # build the runtime image
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

case "${1:-}" in
  --build)
    docker compose -f "$REPO_ROOT/docker/docker-compose.yml" build runtime
    ;;
  "")
    # Ensure bind-mounted paths exist (Docker creates dirs as root if missing)
    touch ~/.gitconfig ~/.claude.json
    mkdir -p ~/.claude ~/.config/gh

    docker compose -f "$REPO_ROOT/docker/docker-compose.yml" run --rm \
        --entrypoint zsh \
        runtime
    ;;
  *)
    echo "Usage: $0 [--build]" >&2
    exit 1
    ;;
esac
