#!/usr/bin/env bash
# Manage the dev container (CPU-only, Mac/CI).
#
# Usage:
#   ./bin/docker_dev           # enter the container (default)
#   ./bin/docker_dev --start   # enter the container
#   ./bin/docker_dev --build   # build the dev image
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

CMD="${1:---start}"

case "$CMD" in
  --build)
    docker compose -f "$REPO_ROOT/docker/docker-compose.yml" build dev
    ;;
  --start)
    # Ensure bind-mounted paths exist (Docker creates dirs as root if missing)
    touch ~/.gitconfig ~/.claude.json
    mkdir -p ~/.claude ~/.config/gh

    docker compose -f "$REPO_ROOT/docker/docker-compose.yml" run --rm \
        --entrypoint zsh \
        dev
    ;;
  *)
    echo "Usage: $0 [--build|--start]" >&2
    exit 1
    ;;
esac
