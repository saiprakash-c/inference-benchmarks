#!/usr/bin/env bash
# Build Docker images for inference-benchmarks.
#
# Usage:
#   ./bin/docker_build          # build both dev and runtime
#   ./bin/docker_build dev      # build dev only (CPU, Mac/CI)
#   ./bin/docker_build runtime  # build runtime only (GPU, Thor)
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

TARGET="${1:-}"

if [[ -z "$TARGET" ]]; then
    docker compose -f "$REPO_ROOT/docker/docker-compose.yml" build dev runtime
else
    docker compose -f "$REPO_ROOT/docker/docker-compose.yml" build "$TARGET"
fi
