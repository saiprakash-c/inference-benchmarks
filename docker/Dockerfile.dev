# inference-benchmarks dev image
#
# Lightweight environment for Mac, CI, and any CPU host.
# No inference libs — use for: linting, doc review, Thor orchestration, CI tooling.
#
# Run:  docker compose run dev <command>

FROM python:3.12-slim-bookworm

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# ── System dependencies ────────────────────────────────────────────────────────
# hadolint ignore=DL3008
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    git \
    openssh-client \
    vim \
    zsh \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js 18 LTS (official binary) ─────────────────────────────────────────
ARG NODE_VERSION=18.20.8
ARG TARGETARCH
RUN ARCH=$([ "$TARGETARCH" = "arm64" ] && echo "arm64" || echo "x64") && \
    curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${ARCH}.tar.gz" \
    | tar -xz -C /usr/local --strip-components=1

# ── Claude Code ───────────────────────────────────────────────────────────────
ARG CLAUDE_CODE_VERSION=2.1.92
RUN npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}

# ── Bazel ─────────────────────────────────────────────────────────────────────
ARG BAZEL_VERSION=7.4.1
ARG TARGETARCH
RUN ARCH=$([ "$TARGETARCH" = "arm64" ] && echo "arm64" || echo "x86_64") && \
    curl -fsSL \
    "https://github.com/bazelbuild/bazel/releases/download/${BAZEL_VERSION}/bazel-${BAZEL_VERSION}-linux-${ARCH}" \
    -o /usr/local/bin/bazel \
    && chmod +x /usr/local/bin/bazel

# ── gh CLI ────────────────────────────────────────────────────────────────────
ARG GH_VERSION=2.67.0
RUN ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/') && \
    curl -fsSL \
    "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_${ARCH}.tar.gz" \
    | tar -xz -C /usr/local --strip-components=1 "gh_${GH_VERSION}_linux_${ARCH}/bin/gh"

# ── Python deps from pyproject.toml ───────────────────────────────────────────
COPY pyproject.toml /workspace/pyproject.toml
# hadolint ignore=DL3013
RUN pip install --no-cache-dir "/workspace[dev]"

# ── User ──────────────────────────────────────────────────────────────────────
ARG UID=501
ARG USERNAME=saip
COPY docker/saip.zshrc /tmp/saip.zshrc
RUN useradd -m -l -u ${UID} -s /bin/zsh ${USERNAME} && \
    cat /tmp/saip.zshrc >> /home/${USERNAME}/.zshrc

USER ${USERNAME}

# ── Workspace ─────────────────────────────────────────────────────────────────
WORKDIR /workspace

ENTRYPOINT ["bazel"]
CMD ["help"]
