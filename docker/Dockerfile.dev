# inference-benchmarks dev image
#
# Lightweight development environment for Mac and CI.
# No GPU required — PyTorch runs on CPU.
# Use for: linting, doc review, harness development, result processing.
#
# Run:  docker compose run dev <command>

FROM python:3.12-slim

# ── System dependencies ────────────────────────────────────────────────────────
# hadolint ignore=DL3008
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# ── Bazel ─────────────────────────────────────────────────────────────────────
ARG BAZEL_VERSION=7.4.1
RUN curl -fsSL \
    "https://github.com/bazelbuild/bazel/releases/download/${BAZEL_VERSION}/bazel-${BAZEL_VERSION}-linux-arm64" \
    -o /usr/local/bin/bazel \
    && chmod +x /usr/local/bin/bazel

# ── gh CLI ────────────────────────────────────────────────────────────────────
ARG GH_VERSION=2.67.0
# hadolint ignore=DL4006
RUN curl -fsSL \
    "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_arm64.tar.gz" \
    | tar -xz -C /usr/local --strip-components=1 gh_${GH_VERSION}_linux_arm64/bin/gh

# ── Python deps from pyproject.toml ───────────────────────────────────────────
COPY pyproject.toml /workspace/pyproject.toml
# hadolint ignore=DL3013
RUN pip install --no-cache-dir "/workspace[dev]"

# ── Workspace ─────────────────────────────────────────────────────────────────
WORKDIR /workspace

ENTRYPOINT ["bazel"]
CMD ["help"]
