# .env.example
#
# Copy to .env and populate for local development.
# In GitHub Actions, these are stored as repository secrets.
# See docs/CI.md "GitHub Actions Secrets" for descriptions.
#
# NEVER commit a populated .env file. It is listed in .gitignore.

# SSH key for Thor (path to PEM file locally; key *contents* stored as secret in CI)
THOR_SSH_KEY=            # e.g. ~/.ssh/thor_ed25519
# Note: Thor's IP is discovered automatically via `tailscale status`.
# No THOR_HOST variable needed — Tailscale handles discovery.

# Tailscale auth key — ephemeral key used by CI runner to join the tailnet.
# Generate at https://login.tailscale.com/admin/settings/keys (ephemeral, reusable).
TAILSCALE_AUTH_KEY=

# GitHub token — used by gh CLI and for GHCR push (packages:write scope).
# In GitHub Actions this is the automatic GITHUB_TOKEN.
# Locally, create a PAT with repo + packages:write scopes.
GITHUB_TOKEN=

# Anthropic API key — used by //ci:doc_review for semantic doc checking.
# In GitHub Actions this is stored as a repository secret.
# Locally, create a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
